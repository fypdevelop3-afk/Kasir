rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Auxiliary helper function
    function isValidStoreCode(code) {
      return code is string && code.size() >= 4 && code.size() <= 32 && code.matches('^[a-zA-Z0-9_-]+$');
    }

    match /stores/{storeCode} {
      allow read, write: if isValidStoreCode(storeCode);

      match /products/{productId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /transactions/{transactionId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /cashierExpenses/{expenseId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /operationalExpenses/{expenseId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /investors/{investorId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /storeSettings/{settingsId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /categories/{categoryId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /stockLogs/{logId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /shifts/{shiftId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /toppings/{toppingId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
      match /discounts/{discountId} {
        allow read, write: if isValidStoreCode(storeCode);
      }
    }
  }
}
